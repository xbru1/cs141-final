import java.util.*;
import javafx.scene.*;
import javafx.scene.input.*;

public class InputHandler {

	// Handle a single key press
	public static void handleKey(KeyEvent input) {

		// I'd *really* like to use a switch statement here but unfortunately this is the Java programming language and I can't be smart here

		// Get the KeyCode to reduce the amount of typing I need to do
		KeyCode key = input.getCode();

		// Toggle debug [F12]
		if (key == KeyCode.F12) {
			Globals.debug = !Globals.debug;
			IO.println("Debug: " + Globals.debug);
			
		} 
		// Move up [W, Up Arrow]
		else if (key == KeyCode.W || key == KeyCode.UP) {
			IO.println("Up");
		} 
		// Move left [A, Left Arrow]
		else if (key == KeyCode.A || key == KeyCode.LEFT) {
			IO.println("Left");
		} 
		// Move down [S, Down Arrow]
		else if (key == KeyCode.S || key == KeyCode.DOWN) {
			IO.println("Down");
		} 
		// Move right [D, Right Arrow]
		else if (key == KeyCode.D || key == KeyCode.RIGHT) {
			IO.println("Right");
		}

		// Output the key pressed if debug is enabled
		if (Globals.debug) {
			IO.println("Key pressed: " + input.getCode().toString());
		}
	}
}
