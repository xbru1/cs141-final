import java.util.*;
import javafx.application.*;
import javafx.scene.*;
import javafx.scene.camera.*;
import javafx.scene.image.*;
import javafx.scene.input.*;
import javafx.scene.paint.*;
import javafx.scene.shape.*;
import javafx.scene.text.*;
import javafx.stage.*;

public class Crawler extends Application {
    public static void main(String[] args) {
        launch(args);
    }

    public static Group root = new Group();

    public int tileSize = 60;
    public int resolutionX = 1920;
    public int resolutionY = 1080;

    public void start(Stage stage) {
        // List<String> parameters = getParameters().getRaw();

        Tile t = new Tile(false, "AAAA");

        IO.println(t.toString());

        Text hello = Globals.text("Hello World!", 50, 50);
        hello.setFont(Font.font("Helvetica", FontWeight.BOLD, 36));

        // Rectangle r = Globals.rectangle(20, 20, 20, 20);
        for (int i = 0; i < resolutionX / tileSize; i++) {
            for (int o = 0; o < resolutionY / tileSize; o++) {
                Rectangle r = Globals.rectangle(
                        tileSize * i, tileSize * o, tileSize, tileSize);
                r.setFill(Color.color(
                        Math.random(), Math.random(), Math.random()));
                r.toBack();
                // r.setFill(Color.GRAY);
            }
        }
        // r.setFill(Color.RED);
        // root.getChildren().add(r);

        stage.setTitle("Dungeon Crawler");
        // stage.getIcons().add(new
        // Image("coffee-cup-silhouette-optimized.png"));

        Scene scene = new Scene(root, 1920, 1080);
        // scene.setFill(Color.ALICEBLUE);
        stage.setScene(scene);
        stage.show();

        scene.addEventFilter(KeyEvent.KEY_PRESSED, (KeyEvent event) -> {
            InputHandler.handleKey(event);
            /*if (event.getCode() == KeyCode.F12) {
                debug[0] = !debug[0];
                IO.println("Debug: " + debug[0]);
            }*/
            // IO.println("Key press");
        });
    }

    public static Text text(String str, int x, int y) {
        Text text = new Text(str);
        text.setX(x);
        text.setY(y);
        text.setFocusTraversable(true);
        root.getChildren().add(text);
        return text;
    }
}

